{
  "actorSpecification": 1,
  "name": "sven-scraping-projects",
  "title": "UKE & Apotheker Kammer Scraper",
  "version": "0.1",
  "description": "Scrapes UKE doctor profiles and Apotheker Kammer Hamburg pharmacy listings. Runs both spiders sequentially in a single run.",
  "defaultRunOptions": {
    "timeoutSecs": 14400
  },
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "name": { "type": "string" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "department": { "type": "string" },
          "specialties": { "type": "string" },
          "work_area": { "type": "string" },
          "telephone": { "type": "string" },
          "fax": { "type": "string" },
          "email": { "type": "string" },
          "location": { "type": "string" },
          "languages": { "type": "string" },
          "areas_of_expertise": { "type": "string" },
          "areas_of_activity": { "type": "string" },
          "address": { "type": "string" },
          "phone": { "type": "string" },
          "website": { "type": "string" },
          "source_url": { "type": "string" },
          "entity_type": { "type": "string" },
          "display_name": { "type": "string" },
          "name_title": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "website_url": { "type": "string" },
          "address_freeform": { "type": "string" },
          "street": { "type": "string" },
          "postal_code": { "type": "string" },
          "city": { "type": "string" },
          "location_freeform": { "type": "string" },
          "job_title": { "type": "string" },
          "department_or_unit": { "type": "string" },
          "practice_name": { "type": "string" },
          "practice_relation": { "type": "string" },
          "primary_specialty": { "type": "string" },
          "services_or_focus_areas": { "type": "string" },
          "responsibility_area": { "type": "string" },
          "memberships": { "type": "string" },
          "image_url": { "type": "string" },
          "career_highlights": { "type": "string" },
          "affiliated_facilities": { "type": "string" },
          "llm_content": { "type": "string" },
          "raw_source_fields": { "type": "string" }
        },
        "additionalProperties": { "type": "string" }
      },
      "views": {
        "overview": {
          "title": "Results",
          "transformation": {
            "fields": [
              "source",
              "name",
              "url",
              "job_title",
              "primary_specialty",
              "department",
              "address",
              "phone",
              "email",
              "website"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "source": { "label": "Source", "format": "text" },
              "name": { "label": "Name", "format": "text" },
              "url": { "label": "URL", "format": "link" },
              "job_title": { "label": "Position", "format": "text" },
              "primary_specialty": { "label": "Specialty", "format": "text" },
              "department": { "label": "Department/Unit", "format": "text" },
              "address": { "label": "Address", "format": "text" },
              "phone": { "label": "Phone", "format": "text" },
              "email": { "label": "Email", "format": "text" },
              "website": { "label": "Website", "format": "link" }
            }
          }
        }
      }
    }
  }
}
